{
  "name": "ebay-inventory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "preview": "vite preview",
    "dev": "run-p scss:watch dev:vite",
    "dev:test": "cross-env VITE_NODE_ENV=test vite --port 1421",
    "dev:vite": "vite --port 1420",
    "scss:watch": "scss-bundling watch",
    "build": "tsc -b && vite build",
    "start": "vite --port 1420",
    "lint": "run-s lint:ts lint:scss",
    "lint:ts": "eslint .",
    "lint:scss": "stylelint **/*.scss",
    "test": "run-s test:unit test:integration test:e2e",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration --maxWorkers 1",
    "test:integration:spec": "node src/tests/integrationTestSpec.mjs",
    "test:e2e": "playwright test --workers 1 && rm -rf playwright-report ./test-results",
    "test:e2e:spec": "rm -rf playwright-report ./test-results && node src/tests/testSpec.mjs",
    "test:e2e:ui": "playwright test --workers 1 --ui && rm -rf playwright-report ./test-results",
    "publish": "sh ./publish.sh"
  },
  "dependencies": {
    "@midwest-diesel/mwd-ui": "^1.1.2",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.8.1",
    "axios": "^1.13.6",
    "axios-cookiejar-support": "^6.0.5",
    "html-react-parser": "^5.2.17",
    "jotai": "^2.18.1",
    "node-schedule": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "tough-cookie": "^6.0.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pages": "^0.33.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/node-schedule": "^2.1.8",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "pg": "^8.20.0",
    "sass": "^1.98.0",
    "scss-bundling": "^1.1.4",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.0.4"
  }
}
